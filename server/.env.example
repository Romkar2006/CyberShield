# CyberShield Server — Environment Variables
# Copy this file to .env and fill in your real credentials
# NEVER commit .env to version control

# MongoDB Atlas (get from atlas.mongodb.com → Connect → Drivers)
MONGODB_URI=mongodb+srv://cybershieldAdmin:<db_password>@cybershield.ttpcpja.mongodb.net/?appName=Cybershield

# Server
PORT=5000

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_random_jwt_secret_string_minimum_32_characters_long

# Admin password (you choose this — used for /api/admin/login)
ADMIN_PASSWORD=your_secure_admin_password_here

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# HuggingFace Inference API (get from huggingface.co/settings/tokens)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxx
HF_MODEL_ID=HuggingFaceH4/zephyr-7b-beta

# Gmail SMTP (use App Password — NOT your regular password)
# Enable 2FA → Google Account → Security → App Passwords → Generate
GMAIL_USER=omkarraichur0102@gmail.com
