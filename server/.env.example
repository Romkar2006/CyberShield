# MongoDB Atlas URI (get from mongodb.com/atlas)
MONGODB_URI=mongodb+srv://admin:password@cluster0.xxxxx.mongodb.net/cybershield

# Server Port
PORT=5000

# Security (any long random string)
JWT_SECRET=your_jwt_secret_min_32_chars
ADMIN_PASSWORD=your_admin_password

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# HuggingFace Inference API (get from huggingface.co/settings/tokens)
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxx
HF_MODEL_ID=HuggingFaceH4/zephyr-7b-beta

# Gmail SMTP (use App Password — NOT your regular password)
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_16_chars

# Admin & Notifications
ADMIN_EMAIL=your_alerts_email@gmail.com

# Google AI Studio Gemini API Key (get from aistudio.google.com)
GEMINI_API_KEY=AIza_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx
