\n             <div className=\"flex flex-col gap-4\">\n                <button \n                   onClick={handleLoginClick}\n                   className=\"w-full h-16 bg-cyan-dark text-[#0A0F1E] rounded-2xl font-black text-xs uppercase tracking-[0.3em] flex items-center justify-center gap-3 hover:brightness-110 shadow-[0_4px_20px_rgba(0,212,255,0.2)] transition-all active:scale-95 group\"\n                >\n                   <LogIn size={20} /> Authenticate Access <ArrowRight size={18} className=\"translate-x-0 group-hover:translate-x-2 transition-transform\" />\n                </button>\n                <button \n                   onClick={() => { hideAuthModal(); navigate('/login'); }}\n                   className=\"w-full h-16 bg-white/5 border border-white/5 hover:border-white/20 text-[#64748B] hover:text-white rounded-2xl font-bold text-xs uppercase tracking-[0.3em] transition-all flex items-center justify-center gap-2\"\n                >\n                   <UserPlus size={18} /> New Investigator?\n                </button>\n             </div>\n\n             {/* Footer disclaimer */}\n             <div className=\"mt-8 pt-8 border-t border-white/[0.05] flex items-center justify-center gap-3 text-[9px] font-bold text-[#475569] uppercase tracking-widest\">\n                <ShieldAlert size={12} className=\"text-cyan-dark/50\" />\n                Case Encryption Layer Active — CyberShield India\n             </div>\n          </div>\n        </motion.div>\n      </div>\n    </AnimatePresence>\n  );\n};\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Victus\\OneDrive\\Desktop\\PERSONAL_PROJECT_01\\client\\src\\components\\shared\\BNSSectionPill.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Victus\\OneDrive\\Desktop\\PERSONAL_PROJECT_01\\client\\src\\components\\shared\\BnsTerminal.tsx","messages":[{"rul